{
  "name": "e-comm-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "npm run sync:openapi && vitepress dev docs",
    "docs:build": "npm run sync:openapi && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "sync:openapi": "mkdir -p docs/public/delivery && cp docs/delivery/openapi.yaml docs/public/delivery/openapi.yaml",
    "validate": "node scripts/validate-docs.mjs",
    "prebuild": "npm run validate",
    "build": "npm run docs:build",
    "ci": "npm run validate && npm run docs:build"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "vitepress": "^1.6.3",
    "vue": "^3.5.13"
  }
}
